{
  "id": "research-to-brief",
  "version": "1.0.0",
  "title": "证据到 Brief",
  "audiences": ["营销传播", "内容创作者", "产品GTM", "办公研究"],
  "job_stories": [
    "当我要基于多份资料做决策时，我希望每个关键声明都可追溯，以便知道哪些能发布。",
    "当来源互相冲突时，我希望系统保留冲突而不是擅自平均，以便人工判断。"
  ],
  "inputs": [
    {"name": "research_request", "required": true, "rights_required": false, "formats": ["md", "txt", "json"], "description": "研究问题、用途、截止时间、语言、辖区和来源范围"},
    {"name": "source_manifest", "required": true, "rights_required": true, "formats": ["csv", "json"], "description": "来源、所有者、允许用途、日期和授权状态"}
  ],
  "phases": [
    {
      "id": "preflight", "title": "范围、权利与注入预检", "type": "assistive", "risk": "high",
      "depends_on": [], "inputs": ["input:research_request", "input:source_manifest"],
      "outputs": [{"name": "scope_contract", "required": true}, {"name": "rights_ledger", "required": true}],
      "checks": [{"name": "required_fields", "required": true}, {"name": "rights_fail_closed", "required": true}, {"name": "untrusted_content_is_data", "required": true}],
      "completion": "必填项完整；未知或用途不匹配的来源被隔离；外部内容不拥有工具指令权。",
      "abandon_when": ["关键来源无合法用途", "高风险领域无合格复核者"],
      "retry": {"max_attempts": 2, "change_required": "补充范围或权利凭证", "fallback": "缩小到已授权来源"}
    },
    {
      "id": "research_plan", "title": "问题树与来源优先级", "type": "assistive", "risk": "low",
      "depends_on": ["preflight"], "inputs": ["artifact:scope_contract"],
      "outputs": [{"name": "question_tree", "required": true}, {"name": "source_plan", "required": true}],
      "checks": [{"name": "decision_relevance", "required": true}, {"name": "primary_source_priority", "required": true}],
      "completion": "每个研究问题对应所需证据、首选来源和停止条件。",
      "abandon_when": ["问题无法影响目标决策"],
      "retry": {"max_attempts": 2, "change_required": "重写决策问题或调整来源范围", "fallback": "人工给出最小问题树"}
    },
    {
      "id": "claim_ledger", "title": "声明台账", "type": "assistive", "risk": "medium",
      "depends_on": ["research_plan"], "inputs": ["artifact:question_tree", "artifact:source_plan"],
      "outputs": [{"name": "claims", "required": true}, {"name": "conflicts", "required": true}],
      "checks": [{"name": "citation_complete", "required": true}, {"name": "date_and_scope", "required": true}, {"name": "fact_inference_separated", "required": true}],
      "completion": "每个声明含来源、日期、范围、状态和置信度；冲突未被抹平。",
      "abandon_when": ["关键声明只有不明来源", "精确数字或因果无法核实"],
      "retry": {"max_attempts": 2, "change_required": "补充来源或将声明降级为未证实", "fallback": "删除不可支持的精确表述"}
    },
    {
      "id": "draft", "title": "事实、推断、建议分层成稿", "type": "assistive", "risk": "medium",
      "depends_on": ["claim_ledger"], "inputs": ["artifact:claims", "artifact:conflicts"],
      "outputs": [{"name": "brief_draft", "required": true}],
      "checks": [{"name": "claims_traceable", "required": true}, {"name": "limitations_visible", "required": true}],
      "completion": "草稿中的发布性声明均能回链台账，限制与未决冲突可见。",
      "abandon_when": ["为填满结构而新增无来源事实"],
      "retry": {"max_attempts": 2, "change_required": "删除过度断言或重组结构", "fallback": "交付声明台账与未决问题而非完整 Brief"}
    },
    {
      "id": "adversarial_review", "title": "独立反方审查", "type": "human", "risk": "high",
      "depends_on": ["draft"], "inputs": ["artifact:brief_draft", "artifact:claims"],
      "outputs": [{"name": "review_record", "required": true}],
      "checks": [{"name": "counterexamples_checked", "required": true}, {"name": "high_risk_claims_checked", "required": true}],
      "completion": "未参与起草者明确 approve，或给出 revise/reject。",
      "abandon_when": ["审查者无法独立访问证据", "关键冲突未解决"],
      "retry": {"max_attempts": 2, "change_required": "按审查意见修改声明而非只改措辞", "fallback": "标记为内部草稿"}
    },
    {
      "id": "release_candidate", "title": "发布候选重建", "type": "deterministic", "risk": "high",
      "depends_on": ["adversarial_review"], "inputs": ["artifact:brief_draft", "artifact:review_record"],
      "outputs": [{"name": "final_brief", "required": true}, {"name": "release_manifest", "required": true}],
      "checks": [{"name": "redaction_scan", "required": true}, {"name": "unknown_formats_absent", "required": true}],
      "completion": "从允许字段重建发布候选；敏感扫描、未知格式和人工审查均通过。",
      "abandon_when": ["任何秘密、身份线索或未授权来源仍可能进入发布物"],
      "retry": {"max_attempts": 2, "change_required": "从空模板重新重建", "fallback": "只保留私有交付"}
    }
  ],
  "deliverables": ["claims.csv", "conflicts.md", "brief.md", "review.md", "RELEASE_MANIFEST.json"]
}
